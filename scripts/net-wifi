#!/usr/bin/env bash
set -euo pipefail

AP_CONN="raspike-ap"
WIFI_CONN="netplan-wlan0-isepr"

echo "Switching to classroom Wi-Fi mode..."

sudo nmcli connection down "${AP_CONN}" 2>/dev/null || true
sudo nmcli connection up "${WIFI_CONN}"

echo
echo "Wi-Fi mode is active."
echo "Current wlan0 address:"
ip -4 addr show wlan0
